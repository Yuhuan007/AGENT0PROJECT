# =============================================================================
# Mini Agent Runtime 环境变量配置模板
# 用法：复制为 .env 并填入你自己的 API Key
#   cp .env.example .env
# =============================================================================

# LLM API Key (必需)
# 智谱 GLM: https://open.bigmodel.cn/usercenter/apikeys
LLM_API_KEY=在此填入你的API_KEY

# LLM 模型 ID (必需)
# 智谱示例: glm-4-flash (免费), glm-4, glm-4-plus
# 通义千问示例: qwen-turbo, qwen-plus, qwen-max
# OpenAI 示例: gpt-4o, gpt-4o-mini
LLM_MODEL_ID=glm-4-flash

# LLM Base URL (必需，根据提供商修改)
# 智谱: https://open.bigmodel.cn/api/paas/v4/
# 通义千问 DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# DeepSeek: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# LLM 超时设置(秒，可选，默认 60)
LLM_TIMEOUT=60
